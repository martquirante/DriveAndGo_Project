<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.CustomerHomePage"
             BackgroundColor="#F8FAFC"
             Title="Explore">
    <ScrollView>
        <VerticalStackLayout Padding="20,22,20,30" Spacing="18">
            <Border Padding="24"
                    BackgroundColor="#0F172A"
                    Stroke="#1E293B"
                    StrokeShape="RoundRectangle 30">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Available today"
                               FontSize="13"
                               TextColor="#FDBA74" />
                        <Label Text="Find the right ride"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="Search admin-managed inventory and request your next rental in a few taps."
                               FontSize="13"
                               TextColor="#CBD5E1" />
                    </VerticalStackLayout>
                    <Image Grid.Column="1"
                           Source="logo.png"
                           HeightRequest="64"
                           WidthRequest="84"
                           VerticalOptions="Center"
                           Aspect="AspectFit" />
                </Grid>
            </Border>

            <Border Padding="16"
                    BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="14">
                    <Entry Placeholder="Search brand, model, plate number"
                           Text="{Binding SearchText}"
                           BackgroundColor="#F1F5F9" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Picker Grid.Column="0"
                                Title="Category"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}" />
                        <Picker Grid.Column="1"
                                Title="Sort"
                                ItemsSource="{Binding SortOptions}"
                                SelectedItem="{Binding SelectedSort}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Vehicles}"
                            SelectionMode="Single"
                            SelectionChanged="OnVehicleSelected">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16"
                                BackgroundColor="White"
                                Stroke="#E2E8F0"
                                StrokeShape="RoundRectangle 24">
                            <Grid RowDefinitions="150,Auto,Auto" ColumnDefinitions="*,Auto">
                                <Border Grid.Row="0"
                                        Grid.ColumnSpan="2"
                                        BackgroundColor="#FFF7ED"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20"
                                        Padding="16">
                                    <Image Source="{Binding ImageSource}"
                                           Aspect="AspectFit" />
                                </Border>

                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       Margin="0,14,0,0" />

                                <Border Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,14,0,0"
                                        Padding="10,4"
                                        BackgroundColor="#ECFDF5"
                                        Stroke="#A7F3D0"
                                        StrokeShape="RoundRectangle 14">
                                    <Label Text="{Binding CategoryLabel}"
                                           FontSize="12"
                                           TextColor="#047857" />
                                </Border>

                                <VerticalStackLayout Grid.Row="2"
                                                     Grid.ColumnSpan="2"
                                                     Spacing="6"
                                                     Margin="0,8,0,0">
                                    <Label Text="{Binding PricePerDayLabel}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#EA580C" />
                                    <Label Text="{Binding WithDriverLabel}"
                                           FontSize="12"
                                           TextColor="#475569" />
                                    <Label Text="{Binding PlateNo}"
                                           FontSize="12"
                                           TextColor="#94A3B8" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="#FEF2F2"
                    Stroke="#FCA5A5"
                    StrokeShape="RoundRectangle 18"
                    Padding="14">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#991B1B"
                       FontSize="12" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
