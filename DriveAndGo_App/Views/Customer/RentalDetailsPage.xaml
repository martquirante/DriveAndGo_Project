<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.Views.Customer.RentalDetailsPage"
             BackgroundColor="#F8FAFC"
             Title="Booking Details">
    <ScrollView>
        <VerticalStackLayout Padding="20,22,20,30" Spacing="16">
            <Border Padding="18"
                    BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeShape="RoundRectangle 26">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding Rental.VehicleName}"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#0F172A" />
                    <Label Text="{Binding Rental.DateRangeLabel}"
                           FontSize="13"
                           TextColor="#475569" />
                    <Label Text="{Binding Rental.Destination}"
                           FontSize="13"
                           TextColor="#64748B" />
                    <Label Text="{Binding Rental.TotalAmountLabel}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#EA580C" />
                    <Label Text="{Binding Rental.StatusLabel}"
                           FontSize="12"
                           TextColor="#C2410C" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Payment"
                        Clicked="OnPaymentClicked"
                        BackgroundColor="#EA580C"
                        TextColor="White"
                        CornerRadius="18"
                        HeightRequest="48" />
                <Button Grid.Column="1"
                        Text="Messages"
                        Clicked="OnMessagesClicked"
                        BackgroundColor="#0F172A"
                        TextColor="White"
                        CornerRadius="18"
                        HeightRequest="48" />
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Route"
                        Clicked="OnRouteClicked"
                        BackgroundColor="#E2E8F0"
                        TextColor="#0F172A"
                        CornerRadius="18"
                        HeightRequest="48" />
                <Button Grid.Column="1"
                        Text="Report Issue"
                        Clicked="OnIssueClicked"
                        BackgroundColor="#E2E8F0"
                        TextColor="#0F172A"
                        CornerRadius="18"
                        HeightRequest="48" />
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Extension"
                        Clicked="OnExtensionClicked"
                        BackgroundColor="#E2E8F0"
                        TextColor="#0F172A"
                        CornerRadius="18"
                        HeightRequest="48" />
                <Button Grid.Column="1"
                        Text="Rate Rental"
                        Clicked="OnRatingClicked"
                        BackgroundColor="#E2E8F0"
                        TextColor="#0F172A"
                        CornerRadius="18"
                        HeightRequest="48" />
            </Grid>

            <Button Text="Cancel booking"
                    Command="{Binding CancelCommand}"
                    IsVisible="{Binding CanCancel}"
                    BackgroundColor="#7F1D1D"
                    TextColor="White"
                    CornerRadius="18"
                    HeightRequest="48" />

            <Label Text="Transactions"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#0F172A" />

            <CollectionView ItemsSource="{Binding Transactions}">
                <CollectionView.EmptyView>
                    <Label Text="No payment records yet."
                           TextColor="#94A3B8" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14"
                                Margin="0,0,0,10"
                                BackgroundColor="White"
                                Stroke="#E2E8F0"
                                StrokeShape="RoundRectangle 22">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Method}"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A" />
                                    <Label Text="{Binding Status}"
                                           FontSize="12"
                                           TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding AmountLabel}"
                                       VerticalTextAlignment="Center"
                                       FontAttributes="Bold"
                                       TextColor="#EA580C" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
