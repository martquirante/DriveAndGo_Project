<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.Views.Customer.PaymentPage"
             BackgroundColor="#F8FAFC"
             Title="Payment">
    <VerticalStackLayout Padding="20,22,20,30" Spacing="16">
        <Border Padding="18"
                BackgroundColor="White"
                Stroke="#E2E8F0"
                StrokeShape="RoundRectangle 26">
            <VerticalStackLayout Spacing="14">
                <Label Text="Complete your payment"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#0F172A" />
                <Label Text="{Binding AmountLabel}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#EA580C" />
                <Picker Title="Payment method"
                        ItemsSource="{Binding PaymentMethods}"
                        SelectedItem="{Binding SelectedMethod}" />
                <Button Text="Upload proof"
                        Command="{Binding UploadProofCommand}"
                        IsVisible="{Binding ProofIsRequired}"
                        BackgroundColor="#E2E8F0"
                        TextColor="#0F172A"
                        CornerRadius="18"
                        HeightRequest="48" />
                <Label Text="{Binding ProofUrl}"
                       FontSize="12"
                       TextColor="#64748B" />
                <Button Text="Submit payment"
                        Command="{Binding SubmitPaymentCommand}"
                        BackgroundColor="#EA580C"
                        TextColor="White"
                        CornerRadius="18"
                        HeightRequest="52" />
                <Border IsVisible="{Binding HasError}"
                        BackgroundColor="#FEF2F2"
                        Stroke="#FCA5A5"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#991B1B"
                           FontSize="12" />
                </Border>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
