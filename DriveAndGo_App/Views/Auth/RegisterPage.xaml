<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.Views.Auth.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8FAFC">
    <ScrollView>
        <VerticalStackLayout Padding="24,52,24,32" Spacing="18">
            <Label Text="Create your customer account"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#0F172A" />
            <Label Text="This app stays connected to the same admin and MySQL-backed data flow."
                   FontSize="13"
                   TextColor="#64748B" />

            <Border Padding="22"
                    BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeShape="RoundRectangle 30">
                <VerticalStackLayout Spacing="14">
                    <Entry Placeholder="Full name"
                           Text="{Binding FullName}"
                           BackgroundColor="#F1F5F9" />
                    <Entry Placeholder="Email"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           BackgroundColor="#F1F5F9" />
                    <Entry Placeholder="Phone number"
                           Text="{Binding Phone}"
                           Keyboard="Telephone"
                           BackgroundColor="#F1F5F9" />
                    <Entry Placeholder="Password"
                           Text="{Binding Password}"
                           IsPassword="True"
                           BackgroundColor="#F1F5F9" />
                    <Entry Placeholder="Confirm password"
                           Text="{Binding ConfirmPassword}"
                           IsPassword="True"
                           BackgroundColor="#F1F5F9" />
                    <Button Text="Create account"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#EA580C"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="52" />
                    <Button Text="Back to login"
                            Clicked="OnBackClicked"
                            BackgroundColor="#0F172A"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="48" />
                    <Border IsVisible="{Binding HasError}"
                            BackgroundColor="#FEF2F2"
                            Stroke="#FCA5A5"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#991B1B"
                               FontSize="12" />
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
