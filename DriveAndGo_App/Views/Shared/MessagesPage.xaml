<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.Views.Shared.MessagesPage"
             BackgroundColor="#F8FAFC"
             Title="Messages">
    <Grid RowDefinitions="*,Auto" Padding="20,22,20,20">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Messages}">
            <CollectionView.EmptyView>
                <Label Text="No messages yet."
                       TextColor="#94A3B8" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="14"
                            Margin="0,0,0,10"
                            BackgroundColor="White"
                            Stroke="#E2E8F0"
                            StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding SenderName}"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A" />
                            <Label Text="{Binding Content}"
                                   FontSize="13"
                                   TextColor="#475569" />
                            <Label Text="{Binding SentAtLabel}"
                                   FontSize="11"
                                   TextColor="#94A3B8" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="1"
                Padding="14"
                BackgroundColor="White"
                Stroke="#E2E8F0"
                StrokeShape="RoundRectangle 24">
            <VerticalStackLayout Spacing="10">
                <Entry Placeholder="Type a message"
                       Text="{Binding DraftMessage}"
                       BackgroundColor="#F1F5F9" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="Attach"
                            Command="{Binding AttachFileCommand}"
                            BackgroundColor="#E2E8F0"
                            TextColor="#0F172A"
                            CornerRadius="18"
                            HeightRequest="44" />
                    <Button Grid.Column="1"
                            Text="Send"
                            Command="{Binding SendCommand}"
                            BackgroundColor="#EA580C"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="44" />
                </Grid>
                <Label Text="{Binding AttachmentUrl}"
                       FontSize="11"
                       TextColor="#64748B" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
