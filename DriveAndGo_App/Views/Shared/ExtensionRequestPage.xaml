<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.Views.Shared.ExtensionRequestPage"
             BackgroundColor="#F8FAFC"
             Title="Extension">
    <VerticalStackLayout Padding="20,22,20,30" Spacing="16">
        <Border Padding="18"
                BackgroundColor="White"
                Stroke="#E2E8F0"
                StrokeShape="RoundRectangle 26">
            <VerticalStackLayout Spacing="14">
                <Label Text="Request a rental extension"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#0F172A" />
                <Stepper Minimum="1"
                         Maximum="14"
                         Increment="1"
                         Value="{Binding AddedDays}" />
                <Label Text="{Binding AddedDays}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#0F172A" />
                <Label Text="{Binding EstimatedFeeLabel}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#EA580C" />
                <Button Text="Submit extension request"
                        Command="{Binding SubmitCommand}"
                        BackgroundColor="#EA580C"
                        TextColor="White"
                        CornerRadius="18"
                        HeightRequest="48" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
