<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.Views.Shared.LocationRoutePage"
             BackgroundColor="#F8FAFC"
             Title="Route">
    <ScrollView>
        <VerticalStackLayout Padding="20,22,20,30" Spacing="16">
            <Border Padding="22"
                    BackgroundColor="#0F172A"
                    Stroke="#1E293B"
                    StrokeShape="RoundRectangle 30">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Route and tracking"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Map-ready architecture is wired to MySQL-backed location history."
                           FontSize="13"
                           TextColor="#CBD5E1" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#E0F2FE"
                    Stroke="#7DD3FC"
                    StrokeShape="RoundRectangle 26">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Map placeholder"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#0C4A6E" />
                    <Label Text="{Binding LatestPoint.CoordinateLabel}"
                           FontSize="13"
                           TextColor="#075985" />
                    <Label Text="This screen is ready to swap to an actual MAUI map once the live map control is finalized."
                           FontSize="12"
                           TextColor="#0C4A6E" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding RoutePoints}">
                <CollectionView.EmptyView>
                    <Label Text="No route history has been logged yet."
                           TextColor="#94A3B8" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14"
                                Margin="0,0,0,10"
                                BackgroundColor="White"
                                Stroke="#E2E8F0"
                                StrokeShape="RoundRectangle 20">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding CoordinateLabel}"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A" />
                                <Label Text="{Binding Time}"
                                       FontSize="12"
                                       TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
