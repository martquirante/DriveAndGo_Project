<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#0B1220">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1220" Offset="0.0" />
                <GradientStop Color="#172036" Offset="0.5" />
                <GradientStop Color="#E97416" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="24,56,24,32" Spacing="18">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Customer and Driver App"
                               FontSize="14"
                               TextColor="#FDBA74" />
                        <Label Text="Welcome back"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Theme"
                            Command="{Binding ToggleThemeCommand}"
                            BackgroundColor="#22FFFFFF"
                            BorderColor="#44FFFFFF"
                            BorderWidth="1"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="40" />
                </Grid>

                <Border x:Name="AuthCard"
                        Padding="22"
                        BackgroundColor="#F8FAFC"
                        Stroke="#D8E0EA"
                        StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout Spacing="18">
                        <Image Source="logo.png"
                               HeightRequest="72"
                               WidthRequest="150"
                               HorizontalOptions="Center"
                               Aspect="AspectFit" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="Customer"
                                    Clicked="OnCustomerClicked"
                                    BackgroundColor="#EA580C"
                                    TextColor="White"
                                    CornerRadius="18" />
                            <Button Grid.Column="1"
                                    Text="Driver"
                                    Clicked="OnDriverClicked"
                                    BackgroundColor="#E2E8F0"
                                    TextColor="#334155"
                                    CornerRadius="18" />
                        </Grid>

                        <VerticalStackLayout x:Name="CustomerPanel" Spacing="14">
                            <Label Text="Book vehicles, pay rentals, and track your trip from one polished app."
                                   FontSize="13"
                                   TextColor="#64748B" />
                            <Entry Placeholder="Customer email"
                                   Text="{Binding CustomerEmail}"
                                   Keyboard="Email"
                                   BackgroundColor="#F1F5F9" />
                            <Entry Placeholder="Password"
                                   Text="{Binding CustomerPassword}"
                                   IsPassword="True"
                                   BackgroundColor="#F1F5F9" />
                            <Button Text="Login as Customer"
                                    Command="{Binding CustomerLoginCommand}"
                                    BackgroundColor="#EA580C"
                                    TextColor="White"
                                    CornerRadius="18"
                                    HeightRequest="52" />
                            <Button Text="Create customer account"
                                    Command="{Binding OpenRegisterCommand}"
                                    BackgroundColor="#0F172A"
                                    TextColor="White"
                                    CornerRadius="18"
                                    HeightRequest="48" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="DriverPanel"
                                             Spacing="14"
                                             IsVisible="False">
                            <Label Text="Driver accounts use the same app but land on a dedicated operations dashboard."
                                   FontSize="13"
                                   TextColor="#64748B" />
                            <Entry Placeholder="Driver email"
                                   Text="{Binding DriverEmail}"
                                   Keyboard="Email"
                                   BackgroundColor="#F1F5F9" />
                            <Entry Placeholder="Password"
                                   Text="{Binding DriverPassword}"
                                   IsPassword="True"
                                   BackgroundColor="#F1F5F9" />
                            <Button Text="Login as Driver"
                                    Command="{Binding DriverLoginCommand}"
                                    BackgroundColor="#0F172A"
                                    TextColor="White"
                                    CornerRadius="18"
                                    HeightRequest="52" />
                            <Border BackgroundColor="#FFF7ED"
                                    Stroke="#FDBA74"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <Label Text="Driver account creation stays on the admin side. Use the assigned credentials from Drive &amp; Go."
                                       FontSize="12"
                                       TextColor="#9A3412" />
                            </Border>
                        </VerticalStackLayout>

                        <Border IsVisible="{Binding HasError}"
                                BackgroundColor="#FEF2F2"
                                Stroke="#FCA5A5"
                                StrokeShape="RoundRectangle 18"
                                Padding="14">
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="#991B1B"
                                   FontSize="12" />
                        </Border>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="#EA580C"
                                           HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
