<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DriveAndGo_App.AnimatedSplashPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#0F172A">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08111F" Offset="0.0" />
                <GradientStop Color="#14213D" Offset="0.45" />
                <GradientStop Color="#F97316" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Padding="32,80,32,48"
                             Spacing="18"
                             VerticalOptions="Center">
            <Border x:Name="LogoFrame"
                    Padding="28"
                    BackgroundColor="#22FFFFFF"
                    Stroke="#40FFFFFF"
                    StrokeShape="RoundRectangle 36"
                    HorizontalOptions="Center">
                <Image x:Name="LogoImage"
                       Source="logo.png"
                       HeightRequest="120"
                       WidthRequest="180"
                       Aspect="AspectFit"
                       Opacity="0" />
            </Border>

            <Label x:Name="TitleLabel"
                   Text="Drive &amp; Go"
                   FontSize="34"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="White"
                   Opacity="0" />

            <Label x:Name="SubtitleLabel"
                   Text="Premium vehicle rentals for customers and drivers"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="#E2E8F0"
                   Opacity="0" />

            <ActivityIndicator IsRunning="True"
                               Color="White"
                               HeightRequest="42"
                               WidthRequest="42"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
